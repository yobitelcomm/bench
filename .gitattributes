# Auto-detect text files and perform LF normalization
* text=auto eol=lf

# Force LF for shell scripts (cross-platform)
*.sh text eol=lf
*.bash text eol=lf

# Python source: LF
*.py text eol=lf

# YAML / JSON / TOML / Markdown: LF
*.yaml text eol=lf
*.yml text eol=lf
*.json text eol=lf
*.toml text eol=lf
*.md text eol=lf

# Binary files should not be diffed
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.pdf binary
*.zip binary
*.tar binary
*.gz binary
*.zst binary

# Model weights — use LFS in the future
*.bin filter=lfs diff=lfs merge=lfs -text
*.safetensors filter=lfs diff=lfs merge=lfs -text
*.parquet filter=lfs diff=lfs merge=lfs -text

# Linguist (GitHub language detection): hide vendored / generated files
docs/_build/* linguist-generated
**/.mypy_cache/* linguist-generated
